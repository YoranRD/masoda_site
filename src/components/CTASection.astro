---
import { withBase } from "../lib/links";

interface Action {
  href: string;
  label: string;
  external?: boolean;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  actions: Action[];
}

const { eyebrow, title, body, actions } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="cta-band">
      <div class="cta-copy">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h2>{title}</h2>
        <p>{body}</p>
      </div>

      <div class="button-row">
        {
          actions.map((action) => (
            <a
              class:list={[
                "button",
                action.variant === "secondary" ? "button-secondary" : "button-primary"
              ]}
              href={withBase(action.href)}
              target={action.external ? "_blank" : undefined}
              rel={action.external ? "noopener noreferrer" : undefined}
            >
              {action.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    display: grid;
    gap: 1.1rem;
    padding: clamp(1.55rem, 3vw, 2.35rem);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(201, 164, 127, 0.55);
    background:
      radial-gradient(circle at top left, rgba(207, 117, 72, 0.16), transparent 42%),
      radial-gradient(circle at bottom right, rgba(79, 102, 167, 0.1), transparent 34%),
      linear-gradient(180deg, rgba(255, 252, 247, 0.96), rgba(252, 244, 235, 0.92));
    box-shadow: var(--shadow-soft);
  }

  .cta-copy {
    display: grid;
    gap: 0.9rem;
  }

  .cta-copy h2,
  .cta-copy p {
    margin: 0;
  }

  .cta-copy h2 {
    max-width: 12ch;
  }

  .cta-copy p {
    max-width: 34rem;
  }

  @media (min-width: 860px) {
    .cta-band {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }
  }
</style>
