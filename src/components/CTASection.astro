---
import { withBase } from "../lib/links";

interface Action {
  href: string;
  label: string;
  external?: boolean;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  actions: Action[];
}

const { eyebrow, title, body, actions } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="cta-band">
      <div class="cta-copy">
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        <h2>{title}</h2>
        <p>{body}</p>
      </div>

      <div class="button-row">
        {
          actions.map((action) => (
            <a
              class:list={[
                "button",
                action.variant === "secondary" ? "button-secondary" : "button-primary"
              ]}
              href={withBase(action.href)}
              target={action.external ? "_blank" : undefined}
              rel={action.external ? "noopener noreferrer" : undefined}
            >
              {action.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    display: grid;
    gap: 1rem;
    padding: clamp(1.3rem, 3vw, 2rem);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(201, 164, 127, 0.55);
    background:
      radial-gradient(circle at top left, rgba(217, 121, 76, 0.18), transparent 42%),
      radial-gradient(circle at bottom right, rgba(48, 86, 168, 0.12), transparent 36%),
      rgba(255, 250, 242, 0.92);
    box-shadow: var(--shadow-soft);
  }

  .cta-copy {
    display: grid;
    gap: 0.8rem;
  }

  .cta-copy h2,
  .cta-copy p {
    margin: 0;
  }

  @media (min-width: 860px) {
    .cta-band {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }
  }
</style>

