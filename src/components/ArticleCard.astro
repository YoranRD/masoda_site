---
import { formatDateFrench } from "../lib/date";
import { withBase } from "../lib/links";

interface Props {
  href: string;
  title: string;
  excerpt: string;
  categoryLabel: string;
  publishDate: Date;
}

const { href, title, excerpt, categoryLabel, publishDate } = Astro.props;
---

<article class="surface-card article-card">
  <p class="card-meta">{categoryLabel} · {formatDateFrench(publishDate)}</p>
  <h3>
    <a href={withBase(href)}>{title}</a>
  </h3>
  <p>{excerpt}</p>
  <a class="text-link" href={withBase(href)}>
    Lire l'article
  </a>
</article>

<style>
  .article-card {
    display: grid;
    align-content: start;
    gap: 0.95rem;
    height: 100%;
  }

  .article-card h3,
  .article-card p {
    margin: 0;
  }

  .article-card a {
    text-decoration: none;
  }

  .article-card h3 {
    max-width: 17ch;
  }

  .article-card h3 a:hover {
    color: var(--accent-strong);
  }
</style>
