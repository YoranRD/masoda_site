---
import { withBase } from "../lib/links";

interface Props {
  title: string;
  summary: string;
  detail?: string;
  tags?: string[];
  meta?: string;
  image?: string;
  imageAlt?: string;
  ctaHref?: string;
  ctaLabel?: string;
  external?: boolean;
}

const {
  title,
  summary,
  detail,
  tags = [],
  meta,
  image,
  imageAlt = "",
  ctaHref,
  ctaLabel,
  external = false
} = Astro.props;
---

<article class="surface-card workshop-card">
  {
    image && (
      <div class="workshop-media">
        <img src={withBase(image)} alt={imageAlt} width="1080" height="1350" loading="lazy" />
      </div>
    )
  }

  <div class="workshop-body">
    {meta && <p class="card-meta">{meta}</p>}
    <h3>{title}</h3>
    <p>{summary}</p>
    {detail && <p class="detail-copy">{detail}</p>}
    {
      tags.length > 0 && (
        <ul class="tag-row">
          {tags.map((tag) => <li class="tag">{tag}</li>)}
        </ul>
      )
    }
    {
      ctaHref && ctaLabel && (
        <a
          class="button button-secondary"
          href={withBase(ctaHref)}
          target={external ? "_blank" : undefined}
          rel={external ? "noopener noreferrer" : undefined}
        >
          {ctaLabel}
        </a>
      )
    }
  </div>
</article>

<style>
  .workshop-card {
    display: grid;
    gap: 0;
    height: 100%;
    padding: 0;
    overflow: hidden;
  }

  .workshop-media img {
    width: 100%;
    aspect-ratio: 1.28 / 1;
    object-fit: cover;
  }

  .workshop-body {
    display: grid;
    align-content: start;
    gap: 0.95rem;
    padding: 1.25rem;
  }

  .workshop-body h3,
  .workshop-body p {
    margin: 0;
  }

  .workshop-body h3 {
    max-width: 16ch;
  }

  .detail-copy {
    font-size: 0.98rem;
  }
</style>
