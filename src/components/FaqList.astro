---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="faq-list">
  {
    items.map((item) => (
      <details class="surface-card faq-item">
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))
  }
</div>

<style>
  .faq-list {
    display: grid;
    gap: 0.85rem;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
  }

  .faq-item summary {
    cursor: pointer;
    list-style: none;
    padding: 1rem 1.1rem;
    font-weight: 600;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] summary {
    border-bottom: 1px solid rgba(201, 164, 127, 0.35);
    background: rgba(246, 226, 210, 0.4);
  }

  .faq-item p {
    margin: 0;
    padding: 1rem 1.1rem 1.15rem;
  }
</style>

