---
import { withBase } from "../lib/links";

interface HeroAction {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "text";
  external?: boolean;
}

interface Props {
  eyebrow?: string;
  title: string;
  intro: string;
  actions?: HeroAction[];
  meta?: string[];
  image?: string;
  imageAlt?: string;
  compact?: boolean;
}

const {
  eyebrow,
  title,
  intro,
  actions = [],
  meta = [],
  image,
  imageAlt = "",
  compact = false
} = Astro.props;

const hasAside = Astro.slots.has("aside");
---

<section class:list={["page-hero", compact && "page-hero-compact"]}>
  <div class="container hero-grid">
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="hero-intro">{intro}</p>

      {
        meta.length > 0 && (
          <ul class="tag-row hero-meta" aria-label="Repères principaux">
            {meta.map((item) => <li class="tag">{item}</li>)}
          </ul>
        )
      }

      {
        actions.length > 0 && (
          <div class="button-row">
            {actions.map((action) => (
              <a
                class:list={[
                  "button",
                  action.variant === "secondary" && "button-secondary",
                  action.variant === "text" && "button-text",
                  (action.variant === "primary" || !action.variant) && "button-primary"
                ]}
                href={withBase(action.href)}
                target={action.external ? "_blank" : undefined}
                rel={action.external ? "noopener noreferrer" : undefined}
              >
                {action.label}
              </a>
            ))}
          </div>
        )
      }
    </div>

    {(image || hasAside) && (
      <div class="hero-side">
        {
          image && (
            <figure class="hero-visual">
              <img src={withBase(image)} alt={imageAlt} width="1080" height="1350" loading="eager" />
            </figure>
          )
        }

        {hasAside && <div class="hero-aside"><slot name="aside" /></div>}
      </div>
    )}
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding: clamp(2.7rem, 7vw, 5.2rem) 0 1.8rem;
  }

  .page-hero-compact {
    padding-top: 2.2rem;
  }

  .page-hero::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 78%;
    pointer-events: none;
    background:
      radial-gradient(circle at 10% 14%, rgba(207, 117, 72, 0.12), transparent 32%),
      radial-gradient(circle at 92% 10%, rgba(79, 102, 167, 0.08), transparent 20%);
    opacity: 0.95;
  }

  .hero-grid {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: 1.1rem;
    align-content: start;
  }

  .hero-copy h1 {
    margin-bottom: 0;
    max-width: 11ch;
  }

  .hero-intro {
    margin: 0;
    max-width: 35rem;
    font-size: 1.14rem;
    line-height: 1.7;
  }

  .hero-meta {
    margin: 0;
  }

  .hero-copy :global(.button-row) {
    padding-top: 0.15rem;
  }

  .hero-side {
    display: grid;
    gap: 1rem;
  }

  .hero-visual {
    margin: 0;
    padding: 0.75rem;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid rgba(201, 164, 127, 0.48);
    box-shadow: var(--shadow-soft);
    background:
      linear-gradient(180deg, rgba(255, 252, 247, 0.95), rgba(247, 237, 226, 0.74));
  }

  .hero-visual img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: calc(var(--radius-xl) - 0.5rem);
  }

  .hero-aside {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(340px, 0.9fr);
      gap: 2.2rem;
    }
  }

  @media (max-width: 740px) {
    .hero-copy h1 {
      max-width: 12ch;
    }

    .hero-intro {
      font-size: 1.04rem;
    }
  }
</style>
