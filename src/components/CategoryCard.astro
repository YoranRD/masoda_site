---
import { withBase } from "../lib/links";

interface Props {
  href: string;
  title: string;
  summary: string;
  eyebrow?: string;
  statusLabel?: string;
  image?: string;
  imageAlt?: string;
}

const { href, title, summary, eyebrow, statusLabel, image, imageAlt = "" } = Astro.props;
---

<article class="surface-card category-card">
  {
    image && (
      <div class="category-media">
        <img src={withBase(image)} alt={imageAlt} width="1552" height="1554" loading="lazy" />
      </div>
    )
  }

  <div class="category-body">
    {eyebrow && <p class="card-meta">{eyebrow}</p>}
    <h3>{title}</h3>
    <p>{summary}</p>
    <div class="category-footer">
      {statusLabel && <span class="tag">{statusLabel}</span>}
      <a class="text-link" href={withBase(href)}>
        Explorer
      </a>
    </div>
  </div>
</article>

<style>
  .category-card {
    display: grid;
    height: 100%;
    padding: 0;
    overflow: hidden;
  }

  .category-media img {
    width: 100%;
    aspect-ratio: 1 / 0.92;
    object-fit: cover;
  }

  .category-body {
    display: grid;
    align-content: start;
    gap: 0.95rem;
    padding: 1.22rem;
  }

  .category-body h3,
  .category-body p {
    margin: 0;
  }

  .category-body h3 {
    max-width: 14ch;
  }

  .category-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.15rem;
  }
</style>
