---
import { footerSections, siteIdentity, socialLinks } from "../data/site";
import { withBase } from "../lib/links";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-intro">
      <p class="eyebrow">Masoda</p>
      <p>
        {siteIdentity.description}
      </p>
      <p class="footer-note">
        Certaines futures sélections boutique pourront inclure des liens affiliés, mentionnés avec clarté et choisis pour
        leur cohérence avec l'univers Masoda.
      </p>
    </div>

    {
      footerSections.map((section) => (
        <div>
          <h2 class="footer-title">{section.title}</h2>
          <ul class="footer-list">
            {section.links.map((link) => (
              <li>
                <a href={withBase(link.href)}>{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }

    <div>
      <h2 class="footer-title">Réseaux</h2>
      <ul class="footer-list">
        {
          socialLinks.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {siteIdentity.legalName}</p>
    <p>Paris · France</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding-top: 2.8rem;
    border-top: 1px solid var(--border);
    background:
      radial-gradient(circle at top right, rgba(79, 102, 167, 0.06), transparent 18%),
      linear-gradient(180deg, rgba(255, 251, 245, 0.65) 0%, rgba(244, 232, 219, 0.82) 100%);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(4, minmax(0, 1fr));
    gap: 1.55rem;
  }

  .footer-title {
    margin: 0 0 0.65rem;
    font-size: 1rem;
  }

  .footer-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .footer-list a {
    color: var(--text-soft);
    text-decoration: none;
  }

  .footer-list a:hover {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .footer-note {
    font-size: 0.95rem;
  }

  .footer-intro {
    max-width: 23rem;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.4rem;
    padding: 1rem 0 1.6rem;
    border-top: 1px solid rgba(201, 164, 127, 0.45);
    color: var(--text-soft);
    font-size: 0.95rem;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
