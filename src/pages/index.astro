---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import CategoryCard from "../components/CategoryCard.astro";
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import WorkshopCard from "../components/WorkshopCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeaturedEntries } from "../lib/blog";
import { withBase } from "../lib/links";
import { blogCategoryLabels } from "../data/blog";
import { boutiqueCategories } from "../data/boutique";
import { booking, collaborationHighlights, homePillars, socialLinks } from "../data/site";
import { workshopFormats, archivedEvents } from "../data/workshops";

const blogEntries = await getCollection("blog");
const featuredEntries = getFeaturedEntries(blogEntries, 3);
const highlightedArchive = archivedEvents[0];
---

<BaseLayout
  title="Masoda | Ateliers créatifs afro-centrés, journal lifestyle et future boutique"
  description="Masoda rassemble des ateliers créatifs afro-centrés, un journal inspirant et une future boutique affiliée dans un univers chaleureux et premium."
  canonicalPath="/"
>
  <PageHero
    eyebrow="Hub créatif afro-centré"
    title="Des ateliers pour créer, respirer et se retrouver."
    intro="Masoda réunit des ateliers créatifs afro-centrés, un journal lifestyle sensible et une future curation choisie avec soin. Le cœur du projet reste simple : offrir des moments qui font du bien et donnent envie de revenir."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/ateliers/", label: "Découvrir les ateliers", variant: "secondary" }
    ]}
    meta={["Paris", "Groupes à taille humaine", "Réservation directe"]}
    image="/images/event-paint-jam.jpg"
    imageAlt="Visuel d'ambiance d'un atelier Masoda"
  >
    <div slot="aside" class="surface-card">
      <p class="card-meta">Priorité du moment</p>
      <h2 style="font-size:1.5rem; margin-bottom:0.55rem;">Réserver la prochaine édition</h2>
      <p>{booking.note}</p>
      <a class="button button-secondary" href={booking.url} target="_blank" rel="noopener noreferrer">
        Accéder à la billetterie
      </a>
    </div>

    <div slot="aside" class="callout">
      <p class="card-meta">Ce qui compte ici</p>
      <ul class="simple-list">
        <li>Réserver un atelier en quelques secondes.</li>
        <li>Comprendre vite comment collaborer.</li>
        <li>Retrouver l'univers Masoda via le journal et les réseaux.</li>
      </ul>
    </div>
  </PageHero>

  <section class="section section-tight">
    <div class="container">
      <SectionIntro
        eyebrow="Positionnement"
        title="Un univers hybride, avec l'atelier au premier plan."
        intro="Masoda fait tenir ensemble l'expérience vécue, l'inspiration éditoriale et une future curation sans diluer sa promesse principale : venir créer et partager."
      />

      <div class="grid-3">
        {
          homePillars.map((pillar) => (
            <CategoryCard href={pillar.href} title={pillar.title} summary={pillar.description} statusLabel="Explorer" />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Ateliers"
        title="Des ateliers qui privilégient la présence, le plaisir et le lien."
        intro="Chaque format associe ambiance soignée, geste créatif, musique et qualité d'accueil pour proposer un moment désirable et facile à rejoindre."
      />

      <div class="grid-3">
        {
          workshopFormats.map((format) => (
            <WorkshopCard
              title={format.title}
              summary={format.summary}
              detail={format.detail}
              tags={[...format.tags]}
            />
          ))
        }
      </div>

      <div class="split-grid" style="margin-top:1rem;">
        <div class="surface-card">
          <p class="card-meta">Une édition qui donne le ton</p>
          <h3>{highlightedArchive.title}</h3>
          <p>{highlightedArchive.excerpt}</p>
          <a class="text-link" href={withBase("/evenements/")}>Parcourir les éditions passées</a>
        </div>

        <div class="callout">
          <p class="card-meta">Collaboration & privatisation</p>
          <ul class="simple-list">
            {collaborationHighlights.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Boutique à venir"
        title="Une future curation pensée avec retenue."
        intro="La boutique Masoda se prépare comme une sélection affiliée courte, esthétique et utile, fidèle à l'esprit du projet."
      />

      <div class="grid-3">
        {
          boutiqueCategories.map((category) => (
            <CategoryCard
              href={`/boutique/${category.slug}/`}
              title={category.title}
              summary={category.summary}
              eyebrow="Sélection en préparation"
              statusLabel="À venir"
              image={category.image}
              imageAlt={category.imageAlt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Journal"
        title="Un journal pour prolonger l'expérience Masoda."
        intro="Le blog accompagne les ateliers avec des articles autour du bien-être, de la motivation, du repos, de la confiance et des ressources personnelles."
      />

      <div class="grid-3">
        {
          featuredEntries.map((entry) => (
            <ArticleCard
              href={`/blog/${entry.slug}/`}
              title={entry.data.title}
              excerpt={entry.data.excerpt}
              categoryLabel={blogCategoryLabels[entry.data.category]}
              publishDate={entry.data.publishDate}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="split-grid">
        <div class="surface-card">
          <SectionIntro
            eyebrow="Collaborer"
            title="Masoda s'adresse aussi aux lieux, aux marques et aux communautés."
            intro="L'univers est assez clair pour rassurer, assez vivant pour donner envie de s'associer au projet."
          />
          <ul class="simple-list">
            {collaborationHighlights.map((highlight) => <li>{highlight}</li>)}
          </ul>
          <div class="button-row" style="margin-top:1rem;">
            <a class="button button-primary" href={withBase("/partenaires/")}>Découvrir les collaborations</a>
            <a class="button button-secondary" href={withBase("/contact/")}>Prendre contact</a>
          </div>
        </div>

        <div class="surface-card">
          <SectionIntro
            eyebrow="Réseaux"
            title="Retrouver Masoda là où le projet continue à vivre."
            intro="Les réseaux montrent l'ambiance, les annonces, les inspirations et les prolongements visuels du projet."
          />
          <div class="grid-2">
            {
              socialLinks.map((link) => (
                <article class="surface-card">
                  <p class="card-meta">{link.label}</p>
                  <h3 style="font-size:1.2rem;">{link.handle}</h3>
                  <p>{link.description}</p>
                  <a class="text-link" href={link.url} target="_blank" rel="noopener noreferrer">
                    Ouvrir {link.label}
                  </a>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Passer à l'action"
    title="Entrer dans l'univers Masoda commence par l'atelier."
    body="La réservation reste la première action à rendre évidente, avant les collaborations et la découverte du reste de l'univers."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Parler d'une collaboration", variant: "secondary" }
    ]}
  />
</BaseLayout>
