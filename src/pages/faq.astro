---
import CTASection from "../components/CTASection.astro";
import FaqList from "../components/FaqList.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqItems } from "../data/faq";
import { booking } from "../data/site";
---

<BaseLayout
  title="FAQ | Masoda"
  description="Questions fréquentes autour des ateliers, de la réservation, des collaborations et de la future boutique Masoda."
  canonicalPath="/faq/"
>
  <PageHero
    eyebrow="FAQ"
    title="Les réponses utiles, dans le ton juste."
    intro="Cette page réunit les questions les plus fréquentes autour des ateliers, de la réservation, des collaborations et de la future boutique."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Poser une question", variant: "secondary" }
    ]}
    meta={["Ateliers", "Boutique", "Partenaires"]}
  />

  <section class="section section-tight">
    <div class="container">
      <FaqList items={faqItems} />
    </div>
  </section>

  <CTASection
    eyebrow="Toujours prioritaire"
    title="Si une question reste ouverte, la réservation et le contact restent simples."
    body="L'objectif n'est pas de multiplier les explications, mais de rendre l'action plus facile."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Contacter Masoda", variant: "secondary" }
    ]}
  />
</BaseLayout>
