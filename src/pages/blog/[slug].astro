---
import { getCollection, render } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import CTASection from "../../components/CTASection.astro";
import PageHero from "../../components/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { blogCategoryLabels } from "../../data/blog";
import { booking } from "../../data/site";
import { sortBlogEntries } from "../../lib/blog";
import { formatDateFrench } from "../../lib/date";
import { withBase } from "../../lib/links";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = sortBlogEntries(await getCollection("blog"));
const relatedPosts = allPosts
  .filter((entry) => entry.id !== post.id && entry.data.category === post.data.category)
  .slice(0, 2);
---

<BaseLayout
  title={`${post.data.title} | Blog Masoda`}
  description={post.data.description}
  canonicalPath={`/blog/${post.slug}/`}
  type="article"
>
  <PageHero
    eyebrow={blogCategoryLabels[post.data.category]}
    title={post.data.title}
    intro={post.data.description}
    actions={[
      { href: "/blog/", label: "Retour au blog", variant: "secondary" },
      { href: booking.url, label: booking.label, external: true }
    ]}
    meta={[formatDateFrench(post.data.publishDate), post.data.readingTime]}
    compact={true}
  />

  <section class="section section-tight">
    <div class="container split-grid">
      <article class="surface-card prose" style="padding:1.4rem;">
        <Content />
      </article>

      <aside class="surface-card" aria-label="Compléments de lecture">
        <p class="card-meta">Repère</p>
        <h2 style="font-size:1.45rem; margin-bottom:0.6rem;">Le blog nourrit l'univers, l'atelier reste le cœur.</h2>
        <p>
          Les articles donnent du contexte, des idées et des respirations. La réservation et l'expérience en atelier
          restent la priorité de Masoda.
        </p>
        <div class="button-row" style="margin-top:1rem;">
          <a class="button button-primary" href={booking.url} target="_blank" rel="noopener noreferrer">
            Réserver
          </a>
          <a class="button button-secondary" href={withBase("/ateliers/")}>
            Voir les ateliers
          </a>
        </div>
      </aside>
    </div>
  </section>

  {
    relatedPosts.length > 0 && (
      <section class="section">
        <div class="container">
          <h2>À lire aussi</h2>
          <div class="grid-2">
            {relatedPosts.map((entry) => (
              <ArticleCard
                href={`/blog/${entry.slug}/`}
                title={entry.data.title}
                excerpt={entry.data.excerpt}
                categoryLabel={blogCategoryLabels[entry.data.category]}
                publishDate={entry.data.publishDate}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CTASection
    eyebrow="Continuer"
    title="Le meilleur prolongement reste encore l'expérience vécue."
    body="Après la lecture, Masoda invite surtout à réserver, à partager et à entrer dans l'univers par les ateliers."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/blog/", label: "Retour au journal", variant: "secondary" }
    ]}
  />
</BaseLayout>
