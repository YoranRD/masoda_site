---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import CTASection from "../../components/CTASection.astro";
import PageHero from "../../components/PageHero.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortBlogEntries } from "../../lib/blog";
import { blogCategories, blogCategoryLabels } from "../../data/blog";
import { booking, socialLinks } from "../../data/site";

const entries = sortBlogEntries(await getCollection("blog"));
const pinterestLink = socialLinks.find((link) => link.label === "Pinterest");
---

<BaseLayout
  title="Blog | Masoda"
  description="Le journal Masoda : bien-être, confiance en soi, motivation, repos, arts et ressources personnelles."
  canonicalPath="/blog/"
>
  <PageHero
    eyebrow="Journal / Blog"
    title="Le journal Masoda prolonge l'expérience avec douceur et clarté."
    intro="Le blog accompagne les ateliers avec des textes sensibles, utiles et bien structurés, autour du bien-être, du repos, de la confiance et de l'élan créatif."
    actions={[
      { href: "#articles", label: "Parcourir les articles", variant: "secondary" },
      { href: pinterestLink?.url ?? "/", label: "Ouvrir Pinterest", external: true }
    ]}
    meta={["Bien-être", "Motivation", "Repos", "Arts"]}
  />

  <section class="section section-tight">
    <div class="container">
      <SectionIntro
        eyebrow="Thèmes"
        title="Les sujets que le journal fait circuler."
        intro="Le contenu cherche à rester chaleureux, accessible et nuancé, sans tomber dans le jargon ni dans les promesses excessives."
      />

      <div class="grid-4">
        {
          blogCategories.map((category) => (
            <article class="surface-card">
              <p class="card-meta">{category.label}</p>
              <p>{category.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="articles">
    <div class="container">
      <SectionIntro
        eyebrow="Articles"
        title="Une base éditoriale prête à grandir."
        intro="Les premiers billets installent une voix claire et un socle propre pour faire vivre le journal dans la durée."
      />

      <div class="grid-3">
        {
          entries.map((entry) => (
            <ArticleCard
              href={`/blog/${entry.slug}/`}
              title={entry.data.title}
              excerpt={entry.data.excerpt}
              categoryLabel={blogCategoryLabels[entry.data.category]}
              publishDate={entry.data.publishDate}
            />
          ))
        }
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Passerelle"
    title="Le journal ouvre des pistes, l'atelier fait vivre l'expérience."
    body="Les textes nourrissent l'univers Masoda, mais la première invitation reste toujours de rejoindre un atelier."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/ateliers/", label: "Voir les ateliers", variant: "secondary" }
    ]}
  />
</BaseLayout>
