---
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { booking, collaborationHighlights, contactDetails, socialLinks } from "../data/site";

const partnerReasons = [
  "Une proposition claire, chaleureuse et identifiable dès les premiers écrans.",
  "Un univers qui croise créativité, bien-être, lifestyle et communauté sans devenir confus.",
  "Une direction visuelle premium mais accessible, adaptée à des collaborations éditoriales ou expérientielles."
];

const collaborationTypes = [
  {
    title: "Lieux & hospitality",
    description: "Accueillir une édition Masoda dans un lieu qui valorise la convivialité, la culture ou l'expérience sensible."
  },
  {
    title: "Marques & activations",
    description: "Imaginer une collaboration éditoriale ou un format événementiel cohérent avec le ton de Masoda."
  },
  {
    title: "Créateurs & communautés",
    description: "Co-construire une rencontre, un atelier spécial ou une présence de marque à taille humaine."
  }
];

const instagramLink = socialLinks.find((link) => link.label === "Instagram");
---

<BaseLayout
  title="Partenaires | Masoda"
  description="Proposer une collaboration à Masoda : lieux, marques, créateurs et activations autour d'un univers afro-centré chaleureux et premium."
  canonicalPath="/partenaires/"
>
  <PageHero
    eyebrow="Partenaires"
    title="Collaborer avec Masoda doit rester simple, crédible et premium."
    intro="Le site donne une place claire aux demandes de collaboration pour que les lieux, marques et créateurs comprennent rapidement comment le projet peut prendre forme avec eux."
    actions={[
      { href: "/contact/", label: "Prendre contact" },
      {
        href: `mailto:${contactDetails.email}?subject=Collaboration%20Masoda`,
        label: "Écrire par e-mail",
        variant: "secondary",
        external: true
      }
    ]}
    meta={["Lieux", "Marques", "Créateurs"]}
  >
    <div slot="aside" class="surface-card">
      <p class="card-meta">Ancrage actuel</p>
      <h2 style="font-size:1.45rem; margin-bottom:0.55rem;">Paris comme base, l'atelier comme moteur.</h2>
      <p>
        Certaines éditions se sont tenues autour du cadre BMK Folie-Bamako. D'autres terrains de collaboration restent
        possibles tant qu'ils respectent l'identité du projet.
      </p>
    </div>
  </PageHero>

  <section class="section section-tight">
    <div class="container">
      <SectionIntro
        eyebrow="Formats de collaboration"
        title="Trois portes d'entrée pour travailler avec Masoda."
        intro="La collaboration peut prendre la forme d'une activation, d'un accueil, d'un contenu ou d'une expérience sur mesure."
      />

      <div class="grid-3">
        {
          collaborationTypes.map((item) => (
            <article class="surface-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="surface-card">
        <SectionIntro
          eyebrow="Pourquoi Masoda"
          title="Une proposition qui évite l'entre-deux flou."
          intro="Le projet garde une ligne claire : chaleureux, esthétique, facile à comprendre et ancré dans une vraie expérience."
        />
        <ul class="simple-list">
          {partnerReasons.map((reason) => <li>{reason}</li>)}
        </ul>
      </div>

      <div class="callout">
        <p class="card-meta">Ce que la collaboration peut activer</p>
        <ul class="simple-list">
          {collaborationHighlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Contact utile"
        title="Le plus direct reste l'e-mail, puis Instagram."
        intro="La demande peut être simple : contexte, type de collaboration envisagé, horizon de date et attentes principales."
      />

      <div class="grid-2">
        <article class="surface-card">
          <p class="card-meta">E-mail</p>
          <h3>{contactDetails.email}</h3>
          <p>Le canal le plus simple pour cadrer une demande, un brief ou une première prise de contact.</p>
          <a class="text-link" href={`mailto:${contactDetails.email}?subject=Collaboration%20Masoda`}>
            Envoyer un message
          </a>
        </article>

        <article class="surface-card">
          <p class="card-meta">Instagram</p>
          <h3>{instagramLink?.handle}</h3>
          <p>Utile pour voir l'ambiance générale et poursuivre la conversation après un premier échange.</p>
          <a class="text-link" href={instagramLink?.url ?? "/"} target="_blank" rel="noopener noreferrer">
            Ouvrir Instagram
          </a>
        </article>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Priorité"
    title="Le site favorise d'abord la réservation, puis la collaboration."
    body="Masoda garde cette hiérarchie partout dans l'interface pour rester lisible : ateliers d'abord, partenariats ensuite, réseaux en troisième porte d'entrée."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Envoyer une demande", variant: "secondary" }
    ]}
  />
</BaseLayout>

