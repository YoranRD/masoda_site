---
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { booking, collaborationHighlights, contactDetails, socialLinks } from "../data/site";

const partnerReasons = [
  "Une proposition claire, chaleureuse et identifiable dès les premiers échanges.",
  "Un univers qui relie créativité, bien-être, lifestyle et communauté sans perdre en lisibilité.",
  "Une direction visuelle premium mais accessible, adaptée à des collaborations éditoriales, culturelles ou expérientielles."
];

const collaborationTypes = [
  {
    title: "Lieux & hospitality",
    description: "Accueillir une édition Masoda dans un lieu qui valorise la convivialité, la culture et la qualité d'expérience."
  },
  {
    title: "Marques & activations",
    description: "Imaginer une collaboration éditoriale ou un format événementiel cohérent avec l'esthétique et le ton de Masoda."
  },
  {
    title: "Créateurs & communautés",
    description: "Co-construire une rencontre, un atelier spécial ou une présence de marque à taille humaine et à forte personnalité."
  }
];

const instagramLink = socialLinks.find((link) => link.label === "Instagram");
---

<BaseLayout
  title="Partenaires | Masoda"
  description="Proposer une collaboration à Masoda : lieux, marques, créateurs et activations autour d'un univers afro-centré chaleureux et premium."
  canonicalPath="/partenaires/"
>
  <PageHero
    eyebrow="Partenaires"
    title="Collaborer avec Masoda doit sembler évident dès les premiers échanges."
    intro="Masoda propose un univers clair, chaleureux et crédible pour des lieux, des marques et des créateurs qui cherchent une expérience créative à forte identité."
    actions={[
      { href: "/contact/", label: "Présenter un projet" },
      {
        href: `mailto:${contactDetails.email}?subject=Collaboration%20Masoda`,
        label: "Écrire par e-mail",
        variant: "secondary",
        external: true
      }
    ]}
    meta={["Lieux", "Marques", "Créateurs"]}
  >
    <div slot="aside" class="surface-card">
      <p class="card-meta">Ancrage actuel</p>
      <h2 style="font-size:1.45rem; margin-bottom:0.55rem;">Paris comme ancrage, l'atelier comme point de départ.</h2>
      <p>
        Le projet se déploie depuis Paris autour des ateliers. D'autres terrains de collaboration sont possibles dès lors
        qu'ils respectent l'identité, le rythme et la qualité d'expérience portés par Masoda.
      </p>
    </div>
  </PageHero>

  <section class="section section-tight">
    <div class="container">
      <SectionIntro
        eyebrow="Formats de collaboration"
        title="Trois manières de collaborer avec Masoda."
        intro="Accueil de format, activation de marque, temps fort communautaire : la collaboration peut rester souple sans perdre en clarté."
      />

      <div class="grid-3">
        {
          collaborationTypes.map((item) => (
            <article class="surface-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="surface-card">
        <SectionIntro
          eyebrow="Pourquoi Masoda"
          title="Une proposition identifiable, sans flou de positionnement."
          intro="Masoda articule création, bien-être et lifestyle avec une esthétique assumée et une expérience réellement vécue."
        />
        <ul class="simple-list">
          {partnerReasons.map((reason) => <li>{reason}</li>)}
        </ul>
      </div>

      <div class="callout">
        <p class="card-meta">Ce que la collaboration peut activer</p>
        <ul class="simple-list">
          {collaborationHighlights.map((highlight) => <li>{highlight}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Contact utile"
        title="Présenter un contexte, une date et une intention suffit."
        intro="Un premier message clair permet de cadrer rapidement si la collaboration a du sens."
      />

      <div class="grid-2">
        <article class="surface-card">
          <p class="card-meta">E-mail</p>
          <h3>{contactDetails.email}</h3>
          <p>Le canal le plus direct pour partager un brief, un lieu, un calendrier ou une intention de collaboration.</p>
          <a class="text-link" href={`mailto:${contactDetails.email}?subject=Collaboration%20Masoda`}>
            Envoyer un message
          </a>
        </article>

        <article class="surface-card">
          <p class="card-meta">Instagram</p>
          <h3>{instagramLink?.handle}</h3>
          <p>Utile pour sentir l'ambiance visuelle du projet et prolonger l'échange avec des références concrètes.</p>
          <a class="text-link" href={instagramLink?.url ?? "/"} target="_blank" rel="noopener noreferrer">
            Ouvrir Instagram
          </a>
        </article>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Priorité"
    title="Masoda reste d'abord un projet d'ateliers, puis un partenaire de collaboration."
    body="Cette hiérarchie garde le site lisible, tout en laissant une porte d'entrée claire aux demandes sérieuses."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Envoyer une demande", variant: "secondary" }
    ]}
  />
</BaseLayout>
