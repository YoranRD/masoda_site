---
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import WorkshopCard from "../components/WorkshopCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { booking, contactDetails } from "../data/site";
import { archivedEvents, privateEventUseCases } from "../data/workshops";
import { formatDateRangeFrench } from "../lib/date";
---

<BaseLayout
  title="Événements | Masoda"
  description="Retrouver l'agenda Masoda, l'archive d'éditions passées et les possibilités d'accueil ou de privatisation."
  canonicalPath="/evenements/"
>
  <PageHero
    eyebrow="Événements"
    title="Retrouver le rythme des éditions Masoda."
    intro="Cette page rassemble la réservation du moment, le calendrier public et l'archive des formats déjà passés par Masoda."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: contactDetails.calendarPublicUrl, label: "Ouvrir le calendrier", variant: "secondary", external: true }
    ]}
    meta={["Agenda", "Archive", "Paris"]}
  />

  <section class="section section-tight">
    <div class="container split-grid">
      <div class="surface-card">
        <SectionIntro
          eyebrow="Agenda du moment"
          title="La prochaine édition reste la priorité."
          intro="Le calendrier donne une vue d'ensemble, mais la billetterie reste le chemin le plus direct pour rejoindre l'expérience."
        />
        <p>{booking.note}</p>
        <div class="button-row">
          <a class="button button-primary" href={booking.url} target="_blank" rel="noopener noreferrer">
            Réserver la prochaine édition
          </a>
          <a class="button button-secondary" href={contactDetails.calendarPublicUrl} target="_blank" rel="noopener noreferrer">
            Voir le calendrier public
          </a>
        </div>
      </div>

      <iframe
        class="embed-frame"
        src={contactDetails.calendarEmbedUrl}
        title="Calendrier des événements Masoda"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Archive"
        title="Des éditions passées qui donnent le ton."
        intro="Ces archives montrent l'esprit du projet et les formats déjà portés, sans annoncer des dates non confirmées."
      />

      <div class="grid-2">
        {
          archivedEvents.map((event) => (
            <WorkshopCard
              title={event.title}
              summary={event.excerpt}
              meta={formatDateRangeFrench(new Date(event.start), new Date(event.end))}
              image={event.image}
              imageAlt={`Visuel associé à ${event.title}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Accueillir"
        title="Un lieu ou une marque peut accueillir une édition Masoda."
        intro="Quand le contexte est juste, certains formats peuvent être adaptés pour une communauté, un lieu ou une activation partenaire."
      />

      <ul class="key-points">
        {privateEventUseCases.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <CTASection
    eyebrow="Étape suivante"
    title="Réserver d'abord, imaginer un accueil ensuite."
    body="La hiérarchie reste claire : rejoindre la prochaine édition, puis ouvrir une discussion sur un format privé ou partenaire."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Parler d'une édition privée", variant: "secondary" }
    ]}
  />
</BaseLayout>
