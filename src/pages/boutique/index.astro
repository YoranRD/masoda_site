---
import CTASection from "../../components/CTASection.astro";
import CategoryCard from "../../components/CategoryCard.astro";
import PageHero from "../../components/PageHero.astro";
import SectionIntro from "../../components/SectionIntro.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { boutiqueCategories } from "../../data/boutique";
import { socialLinks } from "../../data/site";

const pinterestLink = socialLinks.find((link) => link.label === "Pinterest");
---

<BaseLayout
  title="Boutique | Masoda"
  description="Préparer une future boutique affiliée élégante et éditoriale autour de baya, plantes, nutrition anti-stress, déco et art."
  canonicalPath="/boutique/"
>
  <PageHero
    eyebrow="Boutique affiliée à venir"
    title="Une future boutique pensée comme une sélection de confiance."
    intro="Masoda prépare une mini-boutique affiliée autour d'objets, de matières et de références choisies avec retenue. L'idée n'est pas d'empiler des produits, mais d'ouvrir des pistes cohérentes."
    actions={[
      { href: "/boutique/baya/", label: "Découvrir les catégories", variant: "secondary" },
      { href: pinterestLink?.url ?? "/", label: "Voir Pinterest", external: true }
    ]}
    meta={["Baya", "Plantes", "Déco", "Art"]}
  >
    <div slot="aside" class="callout">
      <p class="card-meta">Cadre actuel</p>
      <p>Aucun achat n'est intégré pour le moment. Les futurs liens n'apparaîtront qu'une fois les références et partenaires réellement validés.</p>
    </div>
  </PageHero>

  <section class="section section-tight">
    <div class="container">
      <SectionIntro
        eyebrow="Catégories"
        title="Cinq univers déjà prêts à accueillir la suite."
        intro="Chaque catégorie dispose d'une base claire pour intégrer, plus tard, des cartes produits et des partenaires cohérents."
      />

      <div class="grid-3">
        {
          boutiqueCategories.map((category) => (
            <CategoryCard
              href={`/boutique/${category.slug}/`}
              title={category.title}
              summary={category.summary}
              eyebrow="Curation en préparation"
              statusLabel="Page prête"
              image={category.image}
              imageAlt={category.imageAlt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Ce qui est déjà prêt"
        title="La structure éditoriale est posée avant les produits."
        intro="Les catégories, les emplacements et le cadre de curation existent déjà pour éviter toute logique catalogue."
      />

      <div class="grid-2">
        {
          boutiqueCategories.map((category) => (
            <article class="surface-card">
              <p class="card-meta">{category.title}</p>
              <h3>{category.lead}</h3>
              <ul class="simple-list">
                {category.placeholderModules.map((module) => <li>{module.description}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="surface-card">
      <SectionIntro
        eyebrow="Ligne éditoriale"
        title="Une sélection courte, claire et alignée avec la marque."
        intro="L'objectif est de recommander peu, mais bien, dans un cadre lisible et crédible."
      />
        <ul class="simple-list">
          <li>Une préférence pour les objets, matières et références qui prolongent réellement l'univers du site.</li>
          <li>Une sélection courte et assumée plutôt qu'un grand nombre de liens peu différenciés.</li>
          <li>Des mentions d'affiliation sobres, lisibles et sans promesse exagérée.</li>
        </ul>
      </div>

      <div class="callout">
        <p class="card-meta">Passerelle naturelle</p>
        <p>
          Pinterest et le journal servent déjà de terrain d'inspiration pour préparer la future boutique : moodboards, objets,
          matières et gestes de mieux-être peuvent y être explorés sans précipiter la recommandation marchande.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    eyebrow="Découvrir"
    title="L'univers Masoda s'explore déjà avant la boutique."
    body="Le journal, Pinterest et les ateliers donnent déjà le ton en attendant les premières références affiliées."
    actions={[
      { href: "/blog/", label: "Lire le journal", variant: "secondary" },
      { href: pinterestLink?.url ?? "/", label: "Ouvrir Pinterest", external: true }
    ]}
  />
</BaseLayout>
