---
import CTASection from "../components/CTASection.astro";
import FaqList from "../components/FaqList.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import WorkshopCard from "../components/WorkshopCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { faqItems } from "../data/faq";
import { booking, collaborationHighlights } from "../data/site";
import {
  archivedEvents,
  atelierAudience,
  atelierBenefits,
  atelierPracticalInfo,
  privateEventUseCases,
  workshopFormats
} from "../data/workshops";
import { formatDateRangeFrench } from "../lib/date";
---

<BaseLayout
  title="Ateliers | Masoda"
  description="Découvrir les formats d'ateliers Masoda, la promesse de l'expérience, les informations pratiques et la réservation du moment."
  canonicalPath="/ateliers/"
>
  <PageHero
    eyebrow="Ateliers"
    title="Des ateliers pensés pour créer, souffler et partager."
    intro="Masoda propose des expériences créatives afro-centrées où l'on vient autant pour le geste que pour l'ambiance : une parenthèse soignée, chaleureuse et accessible."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/evenements/", label: "Voir les éditions passées", variant: "secondary" }
    ]}
    meta={["Réservation simple", "Paris", "Groupes à taille humaine"]}
  >
    <div slot="aside" class="surface-card">
      <p class="card-meta">Réservation</p>
      <h2 style="font-size:1.45rem; margin-bottom:0.55rem;">Billetterie de la prochaine édition</h2>
      <p>La billetterie du moment concentre la prochaine date, les informations pratiques et le cadre de réservation.</p>
      <a class="button button-secondary" href={booking.url} target="_blank" rel="noopener noreferrer">
        Accéder à la billetterie
      </a>
    </div>
  </PageHero>

  <section class="section section-tight">
    <div class="container">
      <SectionIntro
        eyebrow="Promesse"
        title="Ce que l'expérience cherche à laisser."
        intro="Au-delà de l'activité, chaque atelier travaille une sensation de présence, de beauté simple et de lien."
      />

      <div class="grid-3">
        {
          atelierBenefits.map((benefit) => (
            <article class="surface-card">
              <h3>{benefit.title}</h3>
              <p>{benefit.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="surface-card">
        <SectionIntro
          eyebrow="Pour qui"
          title="Des formats accessibles, sans performance à prouver."
          intro="L'expérience reste ouverte aux personnes qui veulent créer, souffler ou partager un beau moment, même sans pratique artistique."
        />
        <ul class="simple-list">
          {atelierAudience.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="surface-card">
        <SectionIntro
          eyebrow="Infos pratiques"
          title="Des repères clairs avant de réserver."
          intro="L'information reste volontairement simple pour laisser la place à l'envie, pas à la confusion."
        />
        <ul class="simple-list">
          {atelierPracticalInfo.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Formats"
        title="Trois manières d'entrer dans l'univers Masoda."
        intro="Les intitulés évoluent selon les cycles, mais l'intention reste la même : relier créativité, mieux-être et qualité de présence."
      />

      <div class="grid-3">
        {
          workshopFormats.map((format) => (
            <WorkshopCard
              title={format.title}
              summary={format.summary}
              detail={format.detail}
              tags={[...format.tags]}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Éditions archivées"
        title="Quelques éditions déjà portées par Masoda."
        intro="Ces repères montrent l'esprit des formats déjà proposés sans annoncer ce qui n'est pas encore confirmé."
      />

      <div class="grid-2">
        {
          archivedEvents.map((event) => (
            <WorkshopCard
              title={event.title}
              summary={event.excerpt}
              meta={formatDateRangeFrench(new Date(event.start), new Date(event.end))}
              image={event.image}
              imageAlt={`Visuel associé à l'atelier ${event.title}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-grid">
      <div class="surface-card">
        <SectionIntro
          eyebrow="Privatiser"
          title="Masoda peut aussi se vivre en format privé ou partenaire."
          intro="Certaines propositions peuvent être adaptées à un lieu, une marque ou une communauté lorsque le contexte est cohérent."
        />
        <ul class="simple-list">
          {privateEventUseCases.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="callout">
        <p class="card-meta">Collaboration</p>
        <ul class="simple-list">
          {collaborationHighlights.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Questions fréquentes"
        title="Les réponses les plus utiles avant de réserver."
      />
      <FaqList items={faqItems} />
    </div>
  </section>

  <CTASection
    eyebrow="Réserver"
    title="Quand l'envie est là, la réservation doit être immédiate."
    body="Tout est conçu pour laisser peu de distance entre la découverte de l'atelier et l'inscription à la prochaine édition."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Imaginer une édition privée", variant: "secondary" }
    ]}
  />
</BaseLayout>
