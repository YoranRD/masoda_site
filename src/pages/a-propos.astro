---
import CTASection from "../components/CTASection.astro";
import PageHero from "../components/PageHero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { booking, siteIdentity } from "../data/site";

const values = [
  {
    title: "Un regard afro-centré assumé",
    description:
      "Masoda valorise des références, des sensibilités et des ambiances ancrées dans des imaginaires afro-diasporiques sans transformer ce regard en posture figée."
  },
  {
    title: "Une chaleur premium",
    description:
      "Le projet cherche une qualité d'accueil et de détail qui reste raffinée, conviviale et jamais froide."
  },
  {
    title: "Une créativité qui fait du bien",
    description:
      "L'art, la musique, la matière, le mouvement et le partage servent ici à retrouver de la présence, de l'élan et de la joie."
  }
];

const makingSteps = [
  "Une intention claire : créer une parenthèse où l'on peut faire, ressentir et partager sans surperformance.",
  "Un cadre visuel cohérent : couleurs, matières, rythme et ambiance sont pensés comme une seule expérience.",
  "Une proposition lisible : lieu, durée, geste créatif et niveau d'accessibilité restent faciles à comprendre.",
  "Une suite éditoriale : le journal, Pinterest et les sélections à venir prolongent l'univers au-delà de la session."
];
---

<BaseLayout
  title="À propos | Masoda"
  description="Comprendre la vision, le ton et la promesse de Masoda : un hub afro-centré où l'atelier reste le cœur du projet."
  canonicalPath="/a-propos/"
>
  <PageHero
    eyebrow="À propos"
    title="Masoda relie création, douceur et art de vivre."
    intro="Le projet est né d'une envie simple : proposer des moments et des contenus qui font de la place au beau, au lien et à une présence plus calme."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/partenaires/", label: "Voir les collaborations", variant: "secondary" }
    ]}
    meta={["Ateliers", "Journal", "Boutique à venir"]}
  >
    <div slot="aside" class="surface-card">
      <p class="card-meta">Identité</p>
      <h2 style="font-size:1.45rem; margin-bottom:0.55rem;">{siteIdentity.tagline}</h2>
      <p>{siteIdentity.description}</p>
    </div>
  </PageHero>

  <section class="section section-tight">
    <div class="container split-grid">
      <div class="surface-card">
        <SectionIntro
          eyebrow="Le cœur du projet"
          title="L'atelier reste le centre de gravité."
          intro="Masoda n'est ni un simple site éditorial, ni une boutique déguisée : l'atelier est la première porte d'entrée, et tout le reste existe pour enrichir cette expérience."
        />
        <p>
          Le journal prolonge l'univers, partage des pistes de mieux-être et donne de la matière aux thèmes qui traversent
          les rencontres. La future boutique viendra plus tard comme un prolongement curaté, pas comme un catalogue massif.
        </p>
      </div>

      <div class="callout">
        <p class="card-meta">Ce que Masoda évite</p>
        <ul class="simple-list">
          <li>Le corporate sans chaleur.</li>
          <li>Les codes pseudo-spirituels sans substance.</li>
          <li>La logique catalogue qui écrase l'identité.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Principes"
        title="Trois repères pour garder la bonne intensité."
        intro="Masoda cherche un équilibre entre qualité d'expérience, lisibilité et profondeur sensible."
      />

      <div class="grid-3">
        {
          values.map((value) => (
            <article class="surface-card">
              <h3>{value.title}</h3>
              <p>{value.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionIntro
        eyebrow="Méthode"
        title="Comment une édition prend forme chez Masoda."
        intro="Chaque proposition reste cadrée pour être désirable, praticable et cohérente avec l'identité du projet."
      />

      <ul class="key-points">
        {makingSteps.map((step) => <li>{step}</li>)}
      </ul>
    </div>
  </section>

  <CTASection
    eyebrow="Prochaine étape"
    title="Découvrir un atelier ou ouvrir un premier échange."
    body="Le site a été conçu pour rendre ces deux gestes simples, avec l'atelier comme point d'entrée principal."
    actions={[
      { href: booking.url, label: booking.label, external: true },
      { href: "/contact/", label: "Écrire à Masoda", variant: "secondary" }
    ]}
  />
</BaseLayout>
